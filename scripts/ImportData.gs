/**
 * 一鍵初始化並匯入所有數據
 */
function initializeAndImport() {
  Logger.log('開始初始化...');
  
  // 初始化表格結構
  initializeSheets();
  
  // 匯入類別
  Logger.log('匯入類別...');
  importCategories();
  
  // 匯入錯誤代碼
  Logger.log('匯入錯誤代碼...');
  importErrorCodes();
  
  Logger.log('✅ 全部完成！');
  
  return {
    success: true,
    message: '初始化和匯入完成！'
  };
}
